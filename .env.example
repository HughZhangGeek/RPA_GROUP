# RPA_GROUP 配置文件模板
# 复制此文件为 .env 并填写实际值

# ==================== API 认证 ====================
# API 密钥（自定义，用于接口鉴权）
API_KEY=your_secret_api_key_here

# ==================== 企业微信配置 ====================
# 企业微信机器人 Webhook URL（用于告警通知）
# 获取方式：企业微信群 -> 群设置 -> 群机器人 -> 添加机器人 -> 复制 Webhook 地址
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxx

# ==================== 服务器配置 ====================
# 服务器外部访问地址（用于生成风控恢复链接）
# 本地开发: 127.0.0.1
# 生产环境: 填写服务器公网 IP 或域名
SERVER_HOST=127.0.0.1

# 服务器端口
SERVER_PORT=8000

# ==================== 队列配置 ====================
# 恢复令牌有效期（秒）
RESUME_TOKEN_EXPIRE=3600

# 队列暂停时轮询间隔（秒）
TASK_RETRY_DELAY=5

# 风控检测间隔（秒）
MONITOR_INTERVAL=1

# ==================== 数据库配置 ====================
# SQLite 数据库路径
DB_PATH=./rpa.db